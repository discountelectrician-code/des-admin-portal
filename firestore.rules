rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Default Catch-All Deny Block
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Core Security Helpers and Claim Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Bootstrapped Administrator Check leveraging runtime configuration
    function isBootstrappedAdmin() {
      return isSignedIn() && request.auth.token.email == 'discountelectrician@gmail.com';
    }

    // New: Helper to safely fetch claims map from the user's document in Firestore
    function getUserDocument() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isBootstrappedAdmin() || (
        isSignedIn() && 
        hasUserDoc() && 
        getUserDocument().data.claims.admin == true
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Custom-Claim Validation Profiles (Blueprint Representation)
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt', 'updatedAt', 'claims'])
        && (data.keys().size() == 6 || (data.keys().size() == 7 && data.keys().hasAll(['employeeProfile'])))
        && data.uid is string
        && data.email is string
        && data.email.size() <= 200
        && data.displayName is string
        && data.displayName.size() <= 100
        && data.claims is map
        && data.claims.keys().hasAll(['admin', 'pay', 'timecard'])
        && data.claims.keys().size() == 3
        && data.claims.admin is bool
        && data.claims.pay is bool
        && data.claims.timecard is bool;
    }

    function isValidTrackingEvent(data) {
      return data.keys().hasAll(['id', 'timestamp', 'eventType', 'subdomain', 'userId', 'userEmail', 'message', 'status', 'details'])
        && data.keys().size() == 9
        && data.id is string
        && data.id.size() <= 128
        && data.userId == request.auth.uid
        && data.userEmail == request.auth.token.email
        && data.eventType is string
        && data.eventType in ['auth', 'payment', 'timecard', 'system', 'error']
        && data.subdomain is string
        && data.subdomain in ['admin', 'pay', 'timecard']
        && data.status is string
        && data.status in ['info', 'success', 'warning', 'error']
        && data.message is string
        && data.message.size() <= 500
        && data.details is string
        && data.details.size() <= 2000;
    }

    function isValidPaymentConfig(data) {
      return data.keys().hasAll(['provider', 'updatedBy', 'updatedAt'])
        && data.provider is string
        && data.provider in ['stripe', 'square']
        && data.updatedBy is string
        && data.updatedAt == request.time
        && (!('stripeSecretKey' in data) || data.stripeSecretKey is string)
        && (!('squareAppId' in data) || data.squareAppId is string)
        && (!('squareAccessToken' in data) || data.squareAccessToken is string);
    }

    function isValidAdminSettings(data) {
      return data.keys().hasAll(['updatedBy', 'updatedAt'])
        && data.updatedBy is string
        && data.updatedAt == request.time
        && (!('gmaps_api_key' in data) || data.gmaps_api_key is string)
        && (!('dataforseo_auth_key' in data) || data.dataforseo_auth_key is string);
    }

    function isValidInvite(data) {
      return data.keys().hasAll(['name', 'cellPhone', 'status', 'createdAt'])
        && data.keys().size() >= 4
        && data.name is string
        && data.name.size() <= 100
        && data.cellPhone is string
        && data.status is string
        && data.status in ['pending', 'claimed']
        && (data.createdAt is string || data.createdAt is timestamp);
    }

    // 4. Entity Access Path Matching
    
    // User Permissions & Custom Claims Sync collection
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      
      // Allow creation by either Owner (for self-signup) OR Admin (for onboarding)
      allow create: if isSignedIn() && isValidId(userId) && (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        isAdmin() || (incoming().claims.admin == false && incoming().claims.pay == false && incoming().claims.timecard == false)
      ) && incoming().createdAt == request.time && incoming().updatedAt == request.time;

      // Allow updates by either Owner or Admin
      allow update: if isSignedIn() && isValidId(userId) && (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        isAdmin() || (
          incoming().claims.admin == existing().claims.admin && 
          incoming().claims.pay == existing().claims.pay && 
          incoming().claims.timecard == existing().claims.timecard
        )
      ) && incoming().createdAt == existing().createdAt && incoming().updatedAt == request.time;
      
      allow delete: if isAdmin();
    }

    // Central Security-Hardened Telemetry collection
    match /tracking_events/{eventId} {
      // Telemetry telemetry displays are reserved for Administrator accounts
      allow read: if isAdmin();

      // Custom-claims based write routing:
      // If logging for a specific subdomain app, you must possess the matching permission claim
      allow create: if isValidId(eventId) && (
        (isSignedIn() && isValidTrackingEvent(incoming()) && (
          isAdmin() || 
          (incoming().subdomain == 'pay' && hasUserDoc() && getUserDocument().data.claims.pay == true) || 
          (incoming().subdomain == 'timecard' && hasUserDoc() && getUserDocument().data.claims.timecard == true)
        )) ||
        // Allow public website telemetry logs
        (incoming().subdomain == 'public')
      );

      // Telemetry logs are strictly append-only; update/delete operations are forbidden
      allow update, delete: if false;
    }

    // New: Live Presence Radar collection for tracking currently active users
    match /live_presence/{presenceId} {
      allow read: if isAdmin();
      allow write: if isValidId(presenceId);
    }

    // New: Abandoned Lead Recovery - Public service request booking forms
    match /service_requests/{id} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() || !isSignedIn() || isSignedIn();
      allow delete: if isAdmin();
    }

    // Central Settings collection for system-wide configurations
    match /settings/{settingId} {
      // Settings containing sensitive API secret tokens are strictly readable only by Administrator accounts
      allow read: if isAdmin();

      // Settings updates are strictly preserved for Administrator accounts
      allow write: if isAdmin() && isValidId(settingId) && (
        (settingId == 'payment_config' && isValidPaymentConfig(incoming())) ||
        (settingId == 'admin_settings' && isValidAdminSettings(incoming()))
      );
    }

    // Secure Onboarding Invitations Ticket Collection (Phase 1 & 3)
    match /invites/{inviteId} {
      // Public users can only retrieve a single document if they possess the exact invite URL identifier;
      // queries (list operations) are strictly prohibited for public protection to avoid index enumeration.
      allow get: if isValidId(inviteId);
      allow list: if isAdmin();

      // Only administrators can mint brand new invitation tickets
      allow create: if isAdmin() && isValidId(inviteId) && isValidInvite(incoming());

      // Public users when claiming their ticket can transition status pending -> claimed
      allow update: if isValidId(inviteId) && (
        isAdmin() || (
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'claimedAt', 'claimedByUid']) &&
          existing().status == 'pending' &&
          incoming().status == 'claimed' &&
          incoming().claimedByUid == request.auth.uid
        )
      );

      // Only central administrators can revoke/delete tickets
      allow delete: if isAdmin();
    }
  }
}
